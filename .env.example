# The deployed instance reads these values from the inline <script> at the top of index.html.
# This file is here as documentation for the values you'd swap in if you fork the project.

# Supabase project URL.
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase publishable (anon) key. Safe to expose in the browser — RLS protects rows.
SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# Postgres table name. The deployed instance uses a per-user prefix because the project is
# shared; if you fork this and run your own Supabase project, "bookmarks" is fine.
SUPABASE_TABLE=bookmarks
